{% extends 'partials/base.html.twig' %}

{% set blog = page.find(page.header.blog_url|defined(theme_var('blog_page')|default('/blog'))) %}
{% set show_breadcrumbs = page.header.show_breadcrumbs|defined(true) %}
{% set show_sidebar = page.header.show_sidebar|defined(true) %}

{% block menu %}
    {{ include('partials/sidebar_right.html.twig') }}
{% endblock %}

{% block content %}
    {% if show_breadcrumbs and config.plugins.breadcrumbs.enabled %}
        <div class="heading">
            {{ include('partials/breadcrumbs.html.twig') }}
        </div>
    {% endif %}

    {{ include('partials/blog_item.html.twig', {listing: false, truncate: false, datestamp: datestamp}) }}

    {% if show_sidebar == false %}
        <section id="footer" class="align-center">
            {{ include('partials/sidebar-bits/footer.html.twig') }}
        </section>
    {% endif %}
{% endblock %}

{% block sidebar %}
{% if show_sidebar == true %}
    {{ include('partials/sidebar_left.html.twig') }}
{% endif %}
{% endblock %}
